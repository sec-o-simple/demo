{
  "$schema": "https://raw.githubusercontent.com/sec-o-simple/sec-o-simple/main/docs/config-schema.json",
  
  "exportTexts": {
    "productDescription": {
      "en": "Standard English product export description template.",
      "de": "Standardisierte deutsche Produktbeschreibung für den Export."
    }
  },
  
  "template": {
    "required": [
      "/document/tracking/id",
      "/vulnerabilities/*/notes"
    ],

    "document-information.title": "Demo Security Advisory",
    "document-information.title.readonly": false,
    "document-information.id": "DEMO-SA-2026-0001",
    "document-information.id.placeholder": "DEMO-SA-YEAR-XXXX",
    "document-information.tracking.status": "final",
    "document-information.language": "en",
    
    "document-information.aliases": [
      "CVE-2099-12345-ADVISORY",
      "INTERNAL-REF-99"
    ],

    "document-information.tlp.label": "WHITE",
    "document-information.tlp.label.placeholder": "Select TLP label",

    "document-information.notes.default": {
      "category": "description"
    },

    "document-information.notes": [
      {
        "id": "tmpl-doc-general-01",
        "category": "general",
        "title": "Advisory Overview",
        "content": "This document contains vital security updates.",
        "content.placeholder": "Enter introductory notes here...",
        "readonly": false
      },
      {
        "id": "legaldisclaimer",
        "category": "legal_disclaimer",
        "title": "Legal Disclaimer",
        "content": "This is an example legal disclaimer. That is added to all advisories by default. You can't edit it or remove it.",
        "readonly": true
      }
    ],

    "document-information.notes_templates": [
      {
        "id": "template_general-01",
        "category": "general",
        "title": "General Information",
        "content": "This is a general information. You can't edit it.",
        "readonly": true
      },
      {
        "id": "template_detail-01",
        "category": "details",
        "title": "Details on product family and product",
        "content": "This is template with details to a product family and product.",
        "readonly": true
      }
    ],

    "document-information.publisher.readonly": false,
    "document-information.publisher.name": "Sec-O-Simple demo publisher",
    "document-information.publisher.category": "vendor",
    "document-information.publisher.namespace": "https://publisher.example.org/",
    "document-information.publisher.contactDetails": "Some contact details that is provided by the template. The user can't edit it.",
    "document-information.publisher.contactDetails.readonly": true,
    "document-information.publisher.issuingAuthority": "Sec-O-Simple company",

    "document-information.references": [
      {
        "id": "ref-01",
        "summary": "Primary Vendor Security Blog",
        "url": "https://vendor.example.com/blog/security-update",
        "origin": "self"
      },
      {
        "id": "ref-02",
        "summary": "External CERT Coordination Center Report",
        "url": "https://cert.example.com/advisories/example",
        "origin": "external"
      }
    ],

    "product_families": [
      {
        "id": "fam-operating-systems",
        "name": "Core OS Platforms",
        "subFamily": {
          "id": "fam-linux-derivatives",
          "name": "Linux-Based Distributions",
          "subFamily": {
            "id": "fam-embedded-linux",
            "name": "Embedded Linux Minimal",
            "subFamily": null
          }
        }
      }
    ],

    "products": [
      {
        "id": "prod-vendor-01",
        "category": "vendor",
        "name": "Enterprise Software Corp",
        "readonly": true,
        "subBranches": [
          {
            "id": "prod-name-01",
            "category": "product_name",
            "familyId": "fam-operating-systems",
            "name": "SecureOS Suite",
            "description": "Enterprise grade operating system ecosystem.",
            "type": "Operating System",
            "readonly": false,
            "subBranches": [
              {
                "id": "prod-ver-01",
                "category": "product_version",
                "name": "v12.4.1",
                "readonly": false,
                "subBranches": []
              },
                            {
                "id": "prod-ver-02",
                "category": "product_version",
                "name": "v12.4.2",
                "readonly": false,
                "subBranches": []
              }
            ]
          }
        ]
      }
    ],

    "vulnerabilities.notes.default": {
      "title": "Standard Vulnerability Description",
      "content": "This is a default summary for a vulnerability.",
      "category": "summary"
    },

    "vulnerabilities.products.default": {
      "status": "known_affected"
    },
    "vulnerabilities.remediations.default": {
      "category": "workaround"
    },
    "vulnerabilities.flags.default": {
      "label": "vulnerable_code_not_in_execute_path"
    },

   "vulnerabilities.notes_templates": [
      {
        "id": "tmpl-vuln-workaround",
        "category": "general",
        "title": "Temporary Mitigation Strategy",
        "content": "Disable the affected port or interface via the firewall configuration rules.",
        "readonly": false
      },
      {
        "id": "tmpl-vuln-faq",
        "category": "faq",
        "title": "Frequently Asked Questions",
        "content": "Q: Is there a workaround?\nA: Yes, see the remediation section.",
        "readonly": true
      }
    ],

     "vulnerabilities": [
      {
        "id": "vuln-01",
        "readonly": false,
        "cve": "CVE-2026-98765",
        "title": "Buffer Overflow in Network Parser Component",
        "cwe": {
          "id": "CWE-120",
          "name": "Buffer Copy without Checking Size of Input ('Classic Buffer Overflow')"
        },
        "notes": [
          {
            "id": "vuln-note-01",
            "category": "details",
            "title": "Execution Vectors",
            "content": "Triggered by sending a malformed packet exceeding 4096 bytes.",
            "readonly": false
          }
        ],
        "references": [
          {
            "id": "vuln-ref-01",
            "summary": "Deep dive exploit analysis report",
            "url": "https://security-research.example.com/cve-2026-98765",
            "category": "external",
            "readonly": true
          }
        ],
        "products": [
          {
            "product_id": "prod-ver-01",
            "status": "known_affected"
          },{
            "product_id": "prod-ver-02",
            "status": "fixed"
          }
        ],
        "remediations": [
          {
            "id": "vuln-remediation-01",
            "category": "workaround",
            "details": "Temporary Mitigation Strategy",
            "content": "Disable the affected port or interface via the firewall configuration rules.",
            "productIds": ["prod-ver-01"]
          }
        ],
        "scores": [
          {
            "id": "vuln-score-01",
            "cvssVersion": "cvss_v3",
            "vectorString": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H",
            "productIds": ["prod-ver-01"],
            "readonly": false
          }
        ] 
      }
    ]
  },

  "productDatabase": {
    "enabled": false,
    "apiUrl": "http://127.0.0.1:9999",
    "url": "http://127.0.0.1:3000"
  },
  "cveApiUrl": "https://cveawg.mitre.org/api/cve"
}
